        <mxCell id="cust-a" value="&lt;b&gt;Customer A — Defense&lt;/b&gt;&#10;Encryption • Signed updates&#10;7-year audit logs • RBAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F3A66;strokeColor=#7EC5FF;strokeWidth=2;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cust-b" value="&lt;b&gt;Customer B — Commercial Telecom&lt;/b&gt;&#10;Bandwidth tiers • Billing&#10;SLA reports • 24-mo retention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F3A66;strokeColor=#7EC5FF;strokeWidth=2;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="570" y="130" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cust-c" value="&lt;b&gt;Customer C — Emergency Response&lt;/b&gt;&#10;Rapid deploy • Simple dashboards&#10;Priority traffic • First responders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F3A66;strokeColor=#7EC5FF;strokeWidth=2;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="860" y="130" width="260" height="80" as="geometry" />
        </mxCell>

        <!-- ===== STAGE 1 — INGESTION ===== -->
        <mxCell id="stage1" value="&lt;b&gt;STAGE 1 — Ingestion&lt;/b&gt;&#10;&#10;Deterministic regex extraction&#10;src/utils.py · extract_requirement_blocks()&#10;&#10;Output: stage1_ingested_requirements.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2440;strokeColor=#6FE6A3;strokeWidth=3;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="270" width="400" height="110" as="geometry" />
        </mxCell>

        <mxCell id="stage1-tag" value="NO LLM&#10;DETERMINISTIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6FE6A3;strokeColor=#6FE6A3;fontColor=#0A0E1A;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="920" y="295" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- ===== STAGE 2 — SRD ===== -->
        <mxCell id="stage2" value="&lt;b&gt;STAGE 2 — SRD Generation&lt;/b&gt;&#10;&#10;System Requirements Document (engineering &quot;shall&quot;)&#10;Subsystem assignment · LLM-assisted&#10;&#10;Output: stage2_srd.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2440;strokeColor=#7EC5FF;strokeWidth=3;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="430" width="400" height="110" as="geometry" />
        </mxCell>

        <mxCell id="stage2-tag" value="LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7EC5FF;strokeColor=#7EC5FF;fontColor=#0A0E1A;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="920" y="465" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- ===== STAGE 3 — SSS (the hero stage) ===== -->
        <mxCell id="stage3" value="&lt;b&gt;STAGE 3 — SSS Generation (HERO STAGE)&lt;/b&gt;&#10;&#10;Unified System / Subsystem Specification&#10;• Merge related SRDs across customers&#10;• Detect conflicts (e.g. retention 7y vs 24mo)&#10;• Mandatory dual traceability:&#10;   source_srd_ids  AND  source_customer_ids&#10;&#10;Output: stage3_sss.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2A1A4A;strokeColor=#B794FF;strokeWidth=4;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="450" y="590" width="500" height="160" as="geometry" />
        </mxCell>

        <mxCell id="stage3-tag" value="LLM&#10;+ CONFLICT&#10;DETECTION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B794FF;strokeColor=#B794FF;fontColor=#0A0E1A;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="970" y="635" width="110" height="60" as="geometry" />
        </mxCell>

        <mxCell id="stage3-conflict" value="⚠ Example conflict caught:&#10;A-REQ-013 (7-yr ops logs)&#10;vs&#10;B-REQ-009 (24-mo billing)&#10;→ SSS-DATA-001 conflict_notes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3A1F1F;strokeColor=#FFB347;strokeWidth=2;fontColor=#FFD07A;fontSize=10;align=center;verticalAlign=middle;arcSize=20;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="610" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- ===== STAGE 4 — FEATURES ===== -->
        <mxCell id="stage4" value="&lt;b&gt;STAGE 4 — Features&lt;/b&gt;&#10;&#10;Group SSS by subsystem prefix → PM-level capabilities&#10;e.g. SSS-SEC-* → &quot;Secure Communications &amp; Key Mgmt&quot;&#10;&#10;Output: stage4_features.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2440;strokeColor=#7EC5FF;strokeWidth=3;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="800" width="400" height="110" as="geometry" />
        </mxCell>

        <mxCell id="stage4-tag" value="LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7EC5FF;strokeColor=#7EC5FF;fontColor=#0A0E1A;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="920" y="835" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- ===== STAGE 5 — PBIs ===== -->
        <mxCell id="stage5" value="&lt;b&gt;STAGE 5 — PBIs&lt;/b&gt;&#10;&#10;Product Backlog Items with Given / When / Then ACs&#10;Dev-ready user stories · Linked back to SSS&#10;&#10;Output: stage5_pbis.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2440;strokeColor=#7EC5FF;strokeWidth=3;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="960" width="400" height="110" as="geometry" />
        </mxCell>

        <mxCell id="stage5-tag" value="LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7EC5FF;strokeColor=#7EC5FF;fontColor=#0A0E1A;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="920" y="995" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- ===== VALIDATION ===== -->
        <mxCell id="validation" value="&lt;b&gt;VALIDATION&lt;/b&gt;&#10;&#10;src/validators.py + schemas.py&#10;• JSON-schema strict conformance&#10;• Every traceability link resolves&#10;• Every SSS has both source_srd_ids and source_customer_ids&#10;• Every PBI AC contains Given / When / Then&#10;• Duplicate-text warnings&#10;&#10;Output: validation_report.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A2F1A;strokeColor=#6FE6A3;strokeWidth=3;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="450" y="1120" width="500" height="170" as="geometry" />
        </mxCell>

        <!-- ===== SCORING ===== -->
        <mxCell id="scoring" value="&lt;b&gt;SCORING&lt;/b&gt;     src/scoring.py&#10;&#10;Weighted across 6 categories:&#10;• Traceability accuracy (25%)   • Deduplication quality (20%)&#10;• Conflict detection (15%)         • Feature quality (15%)&#10;• PBI quality (15%)                    • JSON validity (10%)&#10;&#10;Pass condition: validated AND final_score ≥ 80&#10;Output: score_report.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A2F1A;strokeColor=#6FE6A3;strokeWidth=3;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="450" y="1340" width="500" height="170" as="geometry" />
        </mxCell>

        <!-- ===== FINAL OUTPUTS ===== -->
        <mxCell id="output-label" value="OUTPUTS — All artifacts in outputs/" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#7280A0;" vertex="1" parent="1">
