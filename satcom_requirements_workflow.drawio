        <mxCell id="input-label" value="INPUT — Raw Customer Requirements (.md)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#7280A0;" vertex="1" parent="1">
